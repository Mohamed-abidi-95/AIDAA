
# Environment Configuration for AIDAA Backend

# Server
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=aidaa_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# CORS - Allow frontend on any Vite dev port
CORS_ORIGIN=*

# Frontend URL (used in invitation email link)
FRONTEND_URL=http://localhost:5173

# ============================================================================
# Email (SMTP) — CONFIGURATION REQUISE POUR LES INVITATIONS
# ============================================================================
# OPTION 1 — Gmail (recommandé pour la démo/PFE) :
#   1. Aller sur : myaccount.google.com > Sécurité > Vérification en 2 étapes (activer)
#   2. Puis : myaccount.google.com > Sécurité > Mots de passe des applications
#   3. Créer un mot de passe pour "Autre (nom personnalisé)" → copier les 16 caractères
#   4. Remplir SMTP_USER=votremail@gmail.com et SMTP_PASS=xxxx xxxx xxxx xxxx
#
# OPTION 2 — Laisser vide → Mode Ethereal (emails fictifs, lien visible dans la console)
#   Le lien d'invitation est aussi affiché dans le dashboard parent (bouton "Copier").
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=AIDAA <noreply@aidaa.com>

# ============================================================================
# IA — Gemini API (Google AI Studio — gratuit)
# Obtenir une clé : https://aistudio.google.com/app/apikey
# Laisser vide → mode FAQ keyword-matching uniquement
# ============================================================================
GEMINI_API_KEY=AIzaSyCiWLz3P7OHU9NIKq3v7WFv0qVKKVXwQD8


