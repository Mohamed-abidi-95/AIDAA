
# Environment Configuration for AIDAA Backend

# Server
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=aidaa_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# CORS - Allow frontend on any Vite dev port
CORS_ORIGIN=*

# Frontend URL (used in reset password email link)
FRONTEND_URL=http://localhost:5173

# Email (SMTP) — laisser vide pour utiliser Ethereal (mode démo)
# Remplir pour utiliser Gmail : myaccount.google.com > Sécurité > Mots de passe d'application
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=AIDAA <noreply@aidaa.com>

